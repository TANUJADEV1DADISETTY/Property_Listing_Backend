# ============================================================
# Multi-Region Property Listing Backend - Environment Variables
# Copy this file to .env and fill in the actual values
# ============================================================

# --- US Database ---
POSTGRES_US_DB=properties_us
POSTGRES_US_USER=postgres
POSTGRES_US_PASSWORD=postgres_us_secret

# --- EU Database ---
POSTGRES_EU_DB=properties_eu
POSTGRES_EU_USER=postgres
POSTGRES_EU_PASSWORD=postgres_eu_secret

# --- Kafka ---
KAFKA_BROKER=kafka:29092

# --- Backend US ---
DATABASE_URL_US=postgresql://postgres:postgres_us_secret@db-us:5432/properties_us
REGION_US=us

# --- Backend EU ---
DATABASE_URL_EU=postgresql://postgres:postgres_eu_secret@db-eu:5432/properties_eu
REGION_EU=eu
